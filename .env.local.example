# Painel OuvintePro - copie para .env.local e preencha com os valores do seu projeto Supabase.
# (As mesmas duas variaveis tambem vao nas Environment Variables da Vercel.)
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_anon_key

# Login do painel (tambem nas Environment Variables da Vercel, Production e Preview):
PAINEL_USER=seu_usuario
PAINEL_PASSWORD=sua_senha
SESSION_SECRET=gere_com_openssl_rand_hex_32

# Secrets da Edge Function (NAO vao aqui, vao nos secrets do Supabase):
#   supabase secrets set ZAPI_INSTANCE_ID=xxxx ZAPI_TOKEN=xxxx ZAPI_CLIENT_TOKEN=xxxx
# SUPABASE_URL e SUPABASE_SERVICE_ROLE_KEY sao injetados automaticamente nas Edge Functions.
